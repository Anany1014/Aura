# Environment Variables Example for Aura

# PostgreSQL / pgvector settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/innovation_engine

# OpenAI Configuration (for Embeddings)
OPENAI_API_KEY=your_openai_key_here
EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Configuration (for Claude synthesis & Evaluation)
ANTHROPIC_API_KEY=your_anthropic_key_here
SYNTHESIS_MODEL=claude-3-5-sonnet-20241022

# Cognee Configuration (Limits & metadata boundaries)
COGNEE_METADATA_DIR=.tmp/cognee_meta
COGNEE_MAX_MEMORY_MB=50

# Scheduler settings
RUN_INTERVAL_HOURS=24
BATCH_INGEST_LIMIT=100
TRAVERSAL_HOURLY_LIMIT=50
